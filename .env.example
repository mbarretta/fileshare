# GCS
GCS_BUCKET=your-bucket-name
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json  # or use ADC

# SQLite
DATABASE_PATH=./data/fileshare.db

# Auth (S04)
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_OIDC_ISSUER=https://your-idp.example.com   # optional
AUTH_OIDC_CLIENT_ID=your-client-id               # optional
AUTH_OIDC_CLIENT_SECRET=your-client-secret       # optional

# Cleanup (S06)
CLEANUP_SECRET=generate-with-openssl-rand-base64-32

# App
NEXTAUTH_URL=http://localhost:3000
